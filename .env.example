# Local PostgreSQL/PostGIS settings used by compose.yaml.
# Copy this file to .env only when the defaults need to be overridden.
ADDRESS_DB_NAME=address_system
ADDRESS_DB_USER=address_app
ADDRESS_DB_PASSWORD=address_local_password
ADDRESS_DB_PORT=5432

# Backend-to-backend HMAC authentication. Use a secret manager in production.
ADDRESS_API_SECURITY_ENABLED=true
ADDRESS_API_CLIENT_ID=local-delivery-system
ADDRESS_API_CLIENT_SECRET=local-development-hmac-secret-change-me
ADDRESS_API_ALLOWED_CLOCK_SKEW=5m
ADDRESS_API_REPLAY_RETENTION=15m
ADDRESS_API_REPLAY_CLEANUP_INTERVAL=10m
ADDRESS_API_MAX_REQUEST_BODY_BYTES=65536
ADDRESS_API_RATE_LIMIT_ENABLED=true
ADDRESS_API_RATE_LIMIT_SEARCH_CAPACITY=1000
ADDRESS_API_RATE_LIMIT_SEARCH_REFILL=100
ADDRESS_API_RATE_LIMIT_TARGET_CAPACITY=500
ADDRESS_API_RATE_LIMIT_TARGET_REFILL=50
ADDRESS_API_RATE_LIMIT_DEFAULT_CAPACITY=200
ADDRESS_API_RATE_LIMIT_DEFAULT_REFILL=20
ADDRESS_API_RATE_LIMIT_STALE_RETENTION=24h
ADDRESS_API_RATE_LIMIT_CLEANUP_INTERVAL=1h

# Local Nominatim settings used by the optional `osm` compose profile.
NOMINATIM_PBF_URL=https://download.geofabrik.de/asia/south-korea-latest.osm.pbf
NOMINATIM_PASSWORD=nominatim_local_password
NOMINATIM_PORT=8081
NOMINATIM_IMPORT_THREADS=4
NOMINATIM_API_WORKERS=2
NOMINATIM_SHARED_BUFFERS=1GB
NOMINATIM_MAINTENANCE_WORK_MEM=2GB
NOMINATIM_AUTOVACUUM_WORK_MEM=512MB
NOMINATIM_WORK_MEM=32MB
NOMINATIM_EFFECTIVE_CACHE_SIZE=4GB
NOMINATIM_SHM_SIZE=1gb
NOMINATIM_HEALTH_START_PERIOD=30m

# Address application client settings for the local Nominatim API.
NOMINATIM_BASE_URL=http://localhost:8081
NOMINATIM_CONNECT_TIMEOUT=3s
NOMINATIM_READ_TIMEOUT=10s
NOMINATIM_RETRY_DELAY=5m
NOMINATIM_MAX_RESULTS=10
